; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Raskeladden og Dovreslubben"
run/main_scene="res://scenes/menus/main_menu.tscn"
config/quit_on_go_back=false
config/features=PackedStringArray("4.4", "Mobile")
run/max_fps=60
config/icon="res://assets/art/Logo_R&D_1024x1024.PNG"

[audio]

buses/default_bus_layout="res://materials/default_bus_layout.tres"

[autoload]

SoundManager="*res://scenes/sound_manager.tscn"
GameManager="*res://scenes/game_manager.tscn"

[display]

window/size/viewport_width=1600
window/size/viewport_height=720
window/stretch/mode="viewport"

[dotnet]

project/assembly_name="Raskeladden og Dovreslubben"

[editor_plugins]

enabled=PackedStringArray("res://addons/rmsmartshape/plugin.cfg")

[filesystem]

import/blender/enabled=false

